# Template showing which keys MIDAS needs. No values here.
# Copy to .env and fill in.

# News articles + pre-computed sentiment scores, 2022-present. 15 calls/day.
ALPHAVANTAGE_KEY=

# General news articles, trailing ~30 days. Rolling window — archive daily.
NEWSAPI_KEY=

# Financial news articles, trailing ~1 year. Rolling window — archive daily.
FINNHUB_KEY=

# Macro series (T-bill, CPI, GDP, unemployment, VIX) via FRED/ALFRED vintages.
FRED_KEY=